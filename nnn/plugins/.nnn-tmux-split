#!/usr/bin/env sh
# Shared logic for the tmux-split-h / tmux-split-v nnn plugins.
# $1 = split direction (h|v); $2 = hovered file basename (passed by the wrappers).
# Requires NNN_ORIGIN_PANE (set by tmux-nnn-explorer) — the pane to split in the
# originating tmux window. A tmux popup is not in the window tree, so the target
# pane must be passed in explicitly.

dir="$1"
sel="$2"
[ -z "$NNN_ORIGIN_PANE" ] && exit 0

# Full path of the hovered item ($2/sel is a basename; guard the / root case).
if [ "$PWD" = "/" ]; then
    target="/$sel"
else
    target="$PWD/$sel"
fi

# Split placement (positional params reused as the split-window flags). The `h`
# direction (;l) mirrors tmux-open-target / tmux-claude-open-split: 1 pane in the
# origin window -> split right; 2+ panes -> stack above the rightmost pane. The `v`
# direction (;j) stays an explicit vertical split off the origin pane.
if [ "$dir" = h ]; then
    npanes=$(tmux display -p -t "$NNN_ORIGIN_PANE" '#{window_panes}' 2>/dev/null)
    if [ "${npanes:-1}" -le 1 ]; then
        set -- -h -t "$NNN_ORIGIN_PANE"
    else
        rp=$(tmux list-panes -t "$NNN_ORIGIN_PANE" -F '#{pane_left} #{pane_id}' | sort -n | tail -1 | cut -d' ' -f2)
        set -- -v -b -t "$rp"
    fi
else
    set -- -v -t "$NNN_ORIGIN_PANE"
fi

if [ -n "$sel" ] && [ -d "$target" ]; then
    # directory hovered -> new terminal there
    tmux split-window "$@" -c "$target"
elif [ -n "$sel" ] && [ -e "$target" ]; then
    # file hovered -> open in editor (new pane cwd = browse dir)
    tmux split-window "$@" -c "$PWD" "${EDITOR:-nvim} -- \"$target\""
else
    # empty dir / nothing hovered -> terminal in the browse dir
    tmux split-window "$@" -c "$PWD"
fi

# Close the explorer popup exactly as pressing M-d again does: kill the nnn session
# (not just detach-client, which leaves nnn alive in a detached session and can keep
# the popup open). The outer client lands on the new (active) split.
tmux kill-session -t nnn 2>/dev/null
