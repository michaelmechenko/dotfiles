#!/usr/bin/env sh
# nnn plugin (;g): live ripgrep across the current browse dir. The chosen match opens in an
# nvim split in the origin window at the matched line, then the explorer popup closes.
# Sibling to fzcd. Depends on rg + fzf + bat.
[ -n "$NNN_ORIGIN_PANE" ] || exit 0
type rg >/dev/null 2>&1 || { printf 'rg missing'; read -r _; exit 1; }

# Zoom the nnn pane so fzf + preview fill the popup; restore on exit (mirrors fzcd).
ZOOMED=""
if [ -n "$TMUX" ] && [ "$(tmux display-message -p '#{window_zoomed_flag}' 2>/dev/null)" = "0" ]; then
    tmux resize-pane -Z 2>/dev/null && ZOOMED=1
    trap '[ -n "$ZOOMED" ] && tmux resize-pane -Z 2>/dev/null' EXIT INT HUP TERM
fi

RG='rg --column --line-number --no-heading --color=always --smart-case'
: "${RG_COLORS:=match:fg:216,100,126:style:underline}"
export RG_COLORS
sel=$(fzf --ansi --disabled \
    --bind "start:reload:$RG -- {q} || true" \
    --bind "change:reload:sleep 0.1; $RG -- {q} || true" \
    --bind "alt-q:abort,alt-j:down,alt-k:up,alt-n:preview-half-page-down,alt-u:preview-half-page-up,alt-g:reload:$RG -- {q} || true" \
    --delimiter : \
    --preview 'bat --color=always --style=numbers --theme=ansi --highlight-line {2} -- {1}' \
    --preview-window 'up,60%,border-bottom,+{2}+3/3')
[ -n "$sel" ] || exit 0

f=$(printf '%s\n' "$sel" | cut -d: -f1)
l=$(printf '%s\n' "$sel" | cut -d: -f2)
"$(dirname "$0")/.nnn-open-origin" "$f" "$l"
