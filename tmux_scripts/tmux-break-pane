#!/bin/zsh

# Break the active pane out into its own new window at the end of the session.
# Delegates to the shared crash-safe helper tmux-pane-to-new-window, because the
# installed tmux (Homebrew --HEAD build) crashes the whole server on break-pane.
#
# If the pane was manually renamed via M-t (recorded in @pane-named), name the
# new window after it; otherwise keep tmux's default auto-naming. Invoked via
# `run-shell -b` with the origin pane id ($1); every tmux call targets it
# explicitly so backgrounding can't resolve the wrong pane.

pane="${1:-$(tmux display-message -p '#{pane_id}')}"

# A single-pane window has nothing to break out.
if [ "$(tmux display-message -t "$pane" -p '#{window_panes}')" -le 1 ]; then
    exit 0
fi

name="$(tmux display-message -t "$pane" -p '#{@pane-named}')"

# '' target -> the pane's own session.
newwin="$(~/.config/tmux_scripts/tmux-pane-to-new-window "$pane" '' "$name")"

tmux select-window -t "$newwin"   # mirror break-pane focusing the new window
