#!/usr/bin/env bash
# Open the current pane's Claude session's last response in an nvim split
# (always to the right; see tmux-claude-open-split for placement).

LS="$HOME/.config/tmux_scripts/tmux-claude-ls"
cur=$(tmux display -p '#{pane_id}')
row=$("$LS" | awk -F'\t' -v p="$cur" '$2==p{print; exit}')
[ -n "$row" ] || { tmux display-message "no claude session in this pane"; exit 0; }

transcript=$(printf '%s' "$row" | cut -f7)
[ -f "$transcript" ] || { tmux display-message "no transcript for this session"; exit 0; }

out="$(mktemp -t claude-resp).md"
grep '"type":"assistant"' "$transcript" | tail -1 \
  | jq -r '.message.content[] | select(.type=="text") | .text' 2>/dev/null > "$out"
[ -s "$out" ] || printf '(no text response found)\n' > "$out"

"$HOME/.config/tmux_scripts/tmux-claude-open-split" "$out"
