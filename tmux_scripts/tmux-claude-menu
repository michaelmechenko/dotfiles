#!/usr/bin/env bash
# Cross-tmux Claude session menu (bound to M-b).
#   enter -> focus that session's pane (across any tmux session)
#   k     -> send Enter to every session blocked on a permission prompt
# Colors keyed off COLORS.md roles: rose=waiting, dusty_pink=thinking, inactive=idle.

SELF="$HOME/.config/tmux_scripts/tmux-claude-menu"
LS="$HOME/.config/tmux_scripts/tmux-claude-ls"

case "${1:-}" in
  --colorize)
    "$LS" | awk -F'\t' '
    BEGIN { ESC = sprintf("%c", 27); RST = ESC "[0m" }
    {
      sid=$1; pane=$2; target=$3; sname=$4; state=$5; name=$6; tr=$7; wname=$8;
      if (state == "awaiting-permission") { c = "216;100;126"; tag = "PERMISSION" }
      else if (state == "waiting")        { c = "216;100;126"; tag = "WAITING"    }
      else if (state == "thinking")       { c = "187;157;189"; tag = "thinking"   }
      else                                { c = "101;106;128"; tag = "idle"       }
      loc = wname " · " sname;                 # window-name · tmux-session-name
      if (name != "-") loc = loc " · " name;   # · claude-session-name (when set)
      pre  = ESC "[38;2;" c "m";
      disp = sprintf("%s● %-10s %s%s", pre, tag, loc, RST);
      printf "%s\t%s\t%s\t%s\t%s\n", disp, pane, target, sid, tr;
    }'
    exit 0 ;;

  --preview)
    # Assemble the conversation slice (prev response → question → latest response)
    # plus any plan excerpt as a markdown doc, then highlight it with bat (theme=ansi
    # = the terminal's vague palette, matching the M-d nnn previews). bat wraps to the
    # live preview width via FZF_PREVIEW_COLUMNS, so both the side and bottom layouts fit.
    tr="$2"
    [ -f "$tr" ] || { echo "(no transcript)"; exit 0; }
    a_prev=$(grep '"type":"assistant"' "$tr" | tail -2 | head -1 \
      | jq -r '.message.content[] | select(.type=="text") | .text' 2>/dev/null)
    q=$(grep '"type":"user"' "$tr" | tail -1 \
      | jq -r '.message.content | if type=="array" then map(select(.type=="text") | .text) | join("\n") elif type=="string" then . else "" end' \
      2>/dev/null | head -20)
    a=$(grep '"type":"assistant"' "$tr" | tail -1 \
      | jq -r '.message.content[] | select(.type=="text") | .text' 2>/dev/null)
    plan_rel=$(grep -ho 'claude/plans/[a-z0-9-]*\.md' "$tr" 2>/dev/null \
      | grep -v -- '-agent-' | tail -1)
    {
      if [ -n "$a_prev" ] && [ "$a_prev" != "$a" ]; then
        printf '## prev claude\n\n'; printf '%s\n' "$a_prev" | head -40; printf '\n'
      fi
      [ -n "$q" ] && printf '## you\n\n%s\n\n' "$q"
      if [ -n "$a" ]; then
        printf '## claude\n\n'; printf '%s\n' "$a" | head -200; printf '\n'
      fi
      if [ -n "$plan_rel" ] && [ -f "$HOME/.config/$plan_rel" ]; then
        printf '## plan\n\n'; head -40 "$HOME/.config/$plan_rel"
      fi
    } | bat -l md --color=always --style=plain --paging=never --theme=ansi \
        --terminal-width="${FZF_PREVIEW_COLUMNS:-80}"
    exit 0 ;;

  --accept-all)
    # Send Enter to every session needing user input (approves a permission
    # prompt's highlighted default; takes the default on a question).
    "$LS" | awk -F'\t' '$5=="awaiting-permission" || $5=="waiting" {print $2}' | while read -r p; do
      [ -n "$p" ] && tmux send-keys -t "$p" Enter
    done
    exit 0 ;;

  --inner)
    out=$("$SELF" --colorize | fzf --ansi --delimiter='\t' --with-nth=1 \
      --no-sort --layout=reverse-list --cycle --prompt='claude > ' \
      --header=$'enter focus · k approve · esc/M-b close\nC-j/C-k nav · C-d/C-u scroll preview' \
      --preview "$SELF --preview {5}" \
      --preview-window 'right,58%,wrap,follow,+999999,<80(down,55%)' --preview-wrap-sign='' \
      --bind "tab:down,btab:up,ctrl-j:down,ctrl-k:up,alt-j:down,alt-k:up,ctrl-d:preview-half-page-down,ctrl-u:preview-half-page-up,alt-n:preview-half-page-down,alt-u:preview-half-page-up,alt-q:abort,alt-b:abort,k:execute-silent($SELF --accept-all)+reload($SELF --colorize)")
    [ -n "$out" ] || exit 0
    pane=$(printf '%s' "$out" | cut -f2)
    target=$(printf '%s' "$out" | cut -f3)
    if [ -n "$target" ]; then
      if [ -n "${ORIGIN_CLIENT:-}" ]; then
        tmux switch-client -c "$ORIGIN_CLIENT" -t "$target"
      else
        tmux switch-client -t "$target"
      fi
    fi
    [ -n "$pane" ] && tmux select-pane -t "$pane"
    exit 0 ;;

  *)
    origin=$(tmux display -p '#{client_name}')
    border=$(tmux show -gqv @color-inactive); [ -n "$border" ] || border="#a9b1d6"
    tmux display-popup -E -w 80% -h 70% -b rounded -S "fg=$border" \
      "ORIGIN_CLIENT='$origin' '$SELF' --inner"
    ;;
esac
