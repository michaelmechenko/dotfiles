#!/usr/bin/env bash
# $EDITOR/$VISUAL shim, scoped to Claude via the claude() function in .zshrc.
# Opens the file Claude hands off (ctrl+g draft, etc.) in a tmux split and
# BLOCKS until that split's nvim exits, so Claude reads the edited file back.
# Split direction: 1 pane -> right (-h); 2+ panes -> below (-v).

f="$1"
[ -n "$TMUX" ] || exec nvim "$f"          # not in tmux: edit inline

[ "$(tmux display -p '#{window_panes}')" -ge 2 ] && dir=-v || dir=-h
ch="cc-edit-$$"
tmux split-window "$dir" "nvim '$f'; tmux wait-for -S '$ch'"
tmux wait-for "$ch"
