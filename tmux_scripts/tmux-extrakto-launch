#!/bin/sh
# M-K launcher: record the originating pane in the global tmux environment so the shared
# open tool (tmux-open-target, run by extrakto via `tmux run-shell -b`, which inherits the
# global env) can resolve relative paths against that pane's cwd and split off it.
# Mirrors the nnn explorer's NNN_ORIGIN_PANE pattern.
tmux set-environment -g TMUX_OPEN_PANE "$1"
exec "$HOME/.config/tmux_plugins/extrakto/scripts/open.sh" "$1"
