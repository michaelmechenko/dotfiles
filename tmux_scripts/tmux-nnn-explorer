#!/bin/zsh

set -e

# Placement mode: "float" (default, M-d) = centred popup; "pane" (M-B) = overlay the
# launching pane so the explorer fills it instead of floating.
MODE="${1:-float}"

# Toggle: pressing the launch key from inside the explorer popup closes it
# (the popup hosts a nested tmux client, so tmux intercepts the key here).
if [ "$(tmux display-message -p '#{session_name}')" = "nnn" ]; then
    tmux kill-session -t nnn
    exit 0
fi

# Self-heal exec bits: nnn EXECUTES its plugins directly, so a checkout that didn't honor the
# exec bit (core.fileMode=false) would break ;l/;j/;i/;p/;f. `*` skips dotfiles, so name the
# execed dotfile plugin explicitly (.nnn-plugin-helper is sourced → intentionally left non-exec).
chmod +x "$HOME"/.config/nnn/plugins/* "$HOME"/.config/nnn/plugins/.nnn-tmux-split "$HOME"/.config/nnn/plugins/.nnn-open-origin 2>/dev/null

ORIGIN_PANE="$(tmux display-message -p '#{pane_id}')"
CWD="$(tmux display-message -p '#{pane_current_path}')"
# Pane geometry, used only in "pane" mode to overlay the launching pane. The popup -y anchors
# the popup's BOTTOM edge, so we anchor at popup_pane_bottom (popup_pane_left for -x); both
# account for the status-line offset. pane_width/height give the size.
PANE_W="$(tmux display-message -p '#{pane_width}')"
PANE_H="$(tmux display-message -p '#{pane_height}')"
BORDER_COLOR=$(tmux show-options -gqv @color-inactive)
BORDER_COLOR=${BORDER_COLOR:-"#a9b1d6"}

# in-nnn plugin keys (pressed as ;<key>): ;l horizontal split, ;j vertical split,
# ;e new window (dir -> shell there / file -> nvim, new window cwd = browse dir),
# ;i send a cd command to the origin pane's prompt, ;p toggle file preview,
# ;f fzf fuzzy-jump to a subdir (ctrl-o there opens a file in an nvim split in the origin
# window), ;g live ripgrep -> open match in an nvim split. (nnn keybinds are compiled-in; ; is a mandatory
# plugin prefix — bare keys can't run plugins without recompiling nnn.)
PLUG='l:tmux-split-h;j:tmux-split-v;e:tmux-newwindow;i:cd-origin;p:preview-tui;f:fzcd;g:fzrg'
# colors via ANSI indices -> inherit the terminal's themed (vague) palette.
COLORS='63256325'                          # 4 context colors (lavender/pale/mauve/slate), repeated
FCOLORS='060606020005030801050201'         # blk chr DIR exe reg hard sym miss orph fifo sock unk
SPLITSIZE=60                               # preview pane width % (explorer gets the other 40%)
# preview-tui text-speed knobs: plain bat (no line-number/grid rendering),
# ansi theme (inherits the terminal palette). Image/video previewers left unset
# so those heavy branches never fire.
BATSTYLE=numbers
BATTHEME=vague

PAGER_CMD='moor --no-linenumbers --mousemode=scroll --statusbar=plain'

# fresh session each launch (reaps any lingering detached one), start in origin cwd
tmux kill-session -t nnn 2>/dev/null || true

# Geometry: centred float by default; overlay the launching pane in "pane" mode.
if [ "$MODE" = "pane" ]; then
    GEO=(-t "$ORIGIN_PANE" -x '#{popup_pane_left}' -y '#{popup_pane_bottom}' -w "$PANE_W" -h "$PANE_H")
else
    GEO=(-xC -yC -w80% -h75%)
fi

tmux popup "${GEO[@]}" -S "fg=$BORDER_COLOR" -E \
    "tmux new-session -s nnn -e NNN_ORIGIN_PANE='$ORIGIN_PANE' -e NNN_PLUG='$PLUG' -e NNN_SPLIT=v -e NNN_SPLITSIZE=$SPLITSIZE -e NNN_BATSTYLE=$BATSTYLE -e NNN_BATTHEME=$BATTHEME -e NNN_COLORS='$COLORS' -e NNN_FCOLORS='$FCOLORS' -e NNN_PAGER='$PAGER_CMD' -c '$CWD' nnn -aH -l 1 -P p" || true
