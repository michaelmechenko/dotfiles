#!/bin/sh
# Re-sync every pane's scrollbar style in one window so the transparent slider
# matches each pane's own background: the active pane in a real (unzoomed) split
# is #151316, everything else (inactive panes, or a single/zoomed active pane) is
# #100E11. The slider shows the muted #606079 only when that pane is scrolled up.
# tmux has no per-pane active/inactive scrollbar style, so this pushes per-pane
# `set -p` overrides; running it on every focus/layout change clears the stale
# override the just-deselected pane would otherwise keep.

ACTIVE_BG="#151316"   # active pane bg when split and not zoomed
PLAIN_BG="#100E11"    # single/zoomed active pane, and all inactive panes
SLIDER="#606079"      # visible slider fg

win="${1:-$TMUX_PANE}"   # any pane id in the target window (or current)
zoom=$(tmux display-message -p -t "$win" '#{window_zoomed_flag}')
npanes=$(tmux display-message -p -t "$win" '#{window_panes}')

for pid in $(tmux list-panes -t "$win" -F '#{pane_id}'); do
    info=$(tmux display-message -p -t "$pid" '#{scroll_position}|#{pane_active}')
    spos=${info%%|*}
    active=${info##*|}

    if [ "$active" = 1 ] && [ "$npanes" -gt 1 ] && [ "$zoom" != 1 ]; then
        bg="$ACTIVE_BG"
    else
        bg="$PLAIN_BG"
    fi

    if [ -n "$spos" ] && [ "$spos" -gt 0 ] 2>/dev/null; then
        fg="$SLIDER"          # scrolled -> visible slider
    else
        fg="$bg"              # at bottom -> transparent (slider == own bg)
    fi

    tmux set -p -t "$pid" pane-scrollbars-style "fg=$fg,bg=$bg,width=1,pad=0"
done
